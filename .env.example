COOKIES=
AT_TOKEN=
F_SID=

# MODEL=auto | paste full boq_* string from StreamGenerate in DevTools if it differs from the built-in default.
# BL_PARAM=... — recommended for Plus/premium: paste your browser's exact bl= value (overrides MODEL).
#
# Keepalive batchexecute (optional): KEEPALIVE_F_REQ_PATH=file.json with decoded DevTools `f.req` JSON,
# or KEEPALIVE_F_REQ=... ; KEEPALIVE_RPC=L5adhe if no inferrable rpc in JSON; KEEPALIVE_INNER_PAYLOAD for minimal rpc bodies.
# KEEPALIVE_GOOG_EXT_525001261_JSPB=... to mirror browser x-goog-ext-525001261-jspb exactly.
#
# CLI rendering: set `chat` in config.jsonc, or env below (comfortable|compact, plain|boxed).
# UI_DENSITY=comfortable
# UI_ANSWER_STYLE=boxed
#
# Optional: root config.jsonc (same keys). Environment variables override config.jsonc.
