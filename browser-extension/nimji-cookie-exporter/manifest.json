{
  "manifest_version": 3,
  "name": "Nimji Cookie Exporter",
  "version": "1.0.0",
  "description": "Capture COOKIES, AT_TOKEN, and F_SID for nimji from Gemini web requests.",
  "permissions": ["cookies", "storage", "webRequest", "tabs"],
  "host_permissions": ["https://gemini.google.com/*", "https://*.google.com/*"],
  "icons": {
    "16": "assets/icon16.png",
    "32": "assets/icon32.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Nimji Cookie Exporter",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "assets/icon16.png",
      "32": "assets/icon32.png",
      "48": "assets/icon48.png",
      "128": "assets/icon128.png"
    }
  }
}
